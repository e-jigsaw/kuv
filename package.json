{
  "name": "picsur",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @picsur/api dev",
    "dev:web": "pnpm --filter @picsur/web dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["bcrypt", "sharp"]
  }
}
